digraph G {
0 [label="fibonacci_sum", shape=Mdiamond]
1 [label="Pre: n >= 0", shape=ellipse]
2 [label="Post: sum >= 0", shape=ellipse]
3 [label="let mut fib = vec ! [0 , 1] ;", shape=box]
4 [label="let mut next = 1 ;", shape=box]
5 [label="let mut counter = 2 ;", shape=box]
6 [label="Inv: fib.len() == counter && counter <= n + 1", shape=ellipse]
7 [label="while: counter <= n", shape=diamond]
8 [label="let new_fib = fib [counter - 1] + fib [counter - 2] ;", shape=box]
9 [label="fib . push (new_fib)", shape=box]
10 [label="counter += 1", shape=box]
11 [label="let sum_result = fibonacci_sum (num) ;", shape=box]
12 [label="let mut sum = 0 ;", shape=box]
13 [label="for fib_number in fib.iter().take(n as usize)", shape=diamond]
14 [label="sum += fib_number", shape=box]
15 [label="Sum of the first {} Fibonacci numbers is {}\" , num , sum_result", shape=box]
16 [label="sum", shape=box]
17 [label="main", shape=Mdiamond]
18 [label="let num = 5 ;", shape=box]
0 -> 1 [label=""];
1 -> 2 [label=""];
2 -> 3 [label=""];
3 -> 4 [label=""];
4 -> 5 [label=""];
5 -> 6 [label=""];
6 -> 7 [label=""];
7 -> 8 [label="true"];
8 -> 9 [label=""];
9 -> 10 [label=""];
10 -> 6 [label="back to loop"];
18 -> 11 [label=""];
7 -> 12 [label="false"];
12 -> 13 [label=""];
13 -> 14 [label="true"];
14 -> 13 [label="back to loop"];
11 -> 15 [label=""];
13 -> 16 [label="false"];
17 -> 18 [label=""];
}

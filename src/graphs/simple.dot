digraph G {
0 [label="add", shape=Mdiamond]
1 [label="Pre: a > 0", shape=ellipse]
2 [label="Post: counter == a", shape=ellipse]
3 [label="let mut counter = 0 ;", shape=box]
4 [label="Inv: counter >= 0 && counter <= a", shape=ellipse]
5 [label="while: counter < a", shape=diamond]
6 [label="counter += 1", shape=box]
7 [label="counter", shape=box]
8 [label="if: true", shape=diamond]
9 [label="counter -= 1", shape=box]
10 [label="main", shape=Mdiamond]
11 [label="else if: false", shape=diamond]
12 [label="counter += 1", shape=box]
13 [label="Result: {}\" , result", shape=box]
14 [label="counter = 0", shape=box]
0 -> 1 [label=""];
1 -> 2 [label=""];
2 -> 3 [label=""];
3 -> 4 [label=""];
4 -> 5 [label=""];
5 -> 6 [label="true"];
6 -> 4 [label="back to loop"];
14 -> 7 [label=""];
5 -> 8 [label="false"];
8 -> 9 [label="true"];
9 -> 7 [label=""];
8 -> 11 [label="false"];
11 -> 12 [label="true"];
10 -> 13 [label=""];
11 -> 14 [label="false"];
12 -> 7 [label=""];
}
